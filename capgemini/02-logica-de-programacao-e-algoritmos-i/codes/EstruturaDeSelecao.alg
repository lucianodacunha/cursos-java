algoritmo "EstruturaDeSelecao"
var
    voto: literal
inicio
    escreva("Digite seu voto: ")
    leia(voto)
    
    escolha voto
        caso "20"
            escreval("Vocę votou no Joăo")
        caso "33"
            escreva("Vocę votou no José")
        caso "60"
            escreva("Vocę votou no Antônio")
        outrocaso
            escreva("Vocę votou nulo")
    fimescolha
fimalgoritmo
