algoritmo "TrabalhandoComVariaveis"

var
    nome: caractere
    sobrenome: caractere
    nomeCompleto: caractere

inicio
    Escreval("Informe seu nome: ")
    leia(nome)
    Escreval("Informe seu dobrenome: ")
    leia(sobrenome)
    nomeCompleto <- nome + " " + sobrenome
    Escreval("Nome Completo: ", nomeCompleto)

fimalgoritmo