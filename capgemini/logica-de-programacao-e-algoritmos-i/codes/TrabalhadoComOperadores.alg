algoritmo "TrabalhandoComOperadores"
var
    x, y: inteiro
    z: real
    w: logico
inicio
    Escreval("Entre com um número inteiro: ")
    leia(x)
    Escreval("Entre com um número inteiro: ")
    leia(y)
    Escreval("")
    Escreval("Verifique o resultado das operaçőes: ")

    z <- x + y
    Escreval("Soma de a + b: ",z)
    
    z <- x - y
    Escreval("Subtraçăo de a - b: ",z)
    
    z <- x / y
    Escreval("Divisăo de a / b: ",z)

    z <- x * y
    Escreval("Multiplicaçăo de a * b: ",z)

    z <- x MOD y
    Escreval("Módulo de a MOD b: ",z)

    z <- x DIV y
    Escreval("Divisăo inteira de a DIV b: ",z)

    w <- x < y
    Escreval("Comparaçăo entre a < b: ",w)
fimalgoritmo
